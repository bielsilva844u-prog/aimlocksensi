rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // WARNING: This allows anyone to read user profiles.
      // This is necessary for the current admin panel implementation.
      // For production, implement proper admin roles.
      allow read: if true; 
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /sensitivities/{sensitivityId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update: if false;
      allow delete: if true; // WARNING: Insecure, for admin only.
    }
    match /licenseKeys/{licenseKeyId} {
      allow read: if true;
      
      // Only authenticated users can claim an active key for themselves
      allow update: if request.auth != null 
                    && resource.data.status == 'active'
                    && request.resource.data.status == 'used'
                    && request.resource.data.usedBy == request.auth.uid;
                    
      // Allow creation and deletion from the admin panel (insecure).
      // TODO: Secure this with proper admin roles.
      allow create, delete: if true;
    }
  }
}
